# ── Database (Neon / serverless Postgres) ───────────────────────────────
# Pooled connection — web/API + short-lived invocations
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dda?sslmode=require"
# Direct/unpooled connection (no -pooler host) — long-lived workers + migrations
DATABASE_URL_DIRECT="postgresql://user:pass@ep-xxx.region.aws.neon.tech/dda?sslmode=require"

# ── Queue (Redis / BullMQ) ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Evidence store (Cloudinary) — ALL evidence: raw snapshots + images ──
# CLOUDINARY_URL encodes all three; the app reads it directly.
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="dda-evidence" # base folder for all uploaded evidence
EVIDENCE_DIR="./.evidence"       # local fallback when Cloudinary isn't set (dev)

# ── On-chain (Solana / Pump.fun) ────────────────────────────────────────
SOLANA_RPC_URL=""                # explicit RPC; else derived from Helius; else public mainnet
HELIUS_API_KEY=""
GEYSER_ENDPOINT=""               # optional firehose

# ── Module 2 (GitHub) ───────────────────────────────────────────────────
GITHUB_TOKEN=""

# ── Module 3 (X / Twitter) ──────────────────────────────────────────────
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_SECRET=""
X_READ_PROVIDER_KEY=""           # third-party read provider (following/historical)

# ── LLM (summary only, downstream of persistence) ───────────────────────
# Provider: "anthropic" (default) | "openai" | "nvidia" (Nemotron).
LLM_PROVIDER="anthropic"
LLM_API_KEY=""
LLM_MODEL="claude-sonnet-5"
LLM_BASE_URL=""   # override endpoint for openai/nvidia; defaults per provider
#
# NVIDIA Nemotron example (get the key + exact model id from build.nvidia.com):
#   LLM_PROVIDER="nvidia"
#   LLM_API_KEY="nvapi-..."
#   LLM_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1"
#   LLM_BASE_URL="https://integrate.api.nvidia.com/v1"   # (this is the default for nvidia)

# ── Publisher ───────────────────────────────────────────────────────────
PUBLISHER_DRY_RUN="true"         # set false only with real X OAuth credentials

# ── Security / hardening ────────────────────────────────────────────────
ADMIN_TOKEN=""                   # bearer token for /api/admin/* (unset = fail closed)
ALLOWED_ORIGINS="*"              # comma-separated origins; set explicitly in prod
HELIUS_WEBHOOK_SECRET=""         # require Authorization: Bearer <secret> on /ingest/helius
RATE_LIMIT_MAX="30"              # requests per window per IP on public writes
RATE_LIMIT_WINDOW_SEC="60"
BODY_LIMIT_BYTES="1000000"

# ── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
PUBLIC_BASE_URL="http://localhost:3000"
CONFIG_DIR="./config"
